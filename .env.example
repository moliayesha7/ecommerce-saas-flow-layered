# Application
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
ADMIN_WEB_URL=http://localhost:5173
SUBSCRIBER_WEB_URL=http://localhost:5174
CUSTOMER_WEB_URL=http://localhost:5175

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=saas_commerce
DB_SSL=false
DB_LOGGING=true
DB_SYNCHRONIZE=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Storage (local or s3)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Mail
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@saas-commerce.com
MAIL_FROM_NAME=SaaS Commerce

# bKash Payment
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

# Socket.io
SOCKET_CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Sentry (optional)
SENTRY_DSN=
