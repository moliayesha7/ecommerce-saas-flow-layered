{
  "name": "saas-commerce",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant SaaS eCommerce platform monorepo",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@saas-commerce/api",
    "dev:admin": "turbo run dev --filter=@saas-commerce/admin-web",
    "dev:subscriber": "turbo run dev --filter=@saas-commerce/subscriber-web",
    "dev:customer": "turbo run dev --filter=@saas-commerce/customer-web",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter=@saas-commerce/api run db:migrate",
    "db:seed": "pnpm --filter=@saas-commerce/api run db:seed",
    "db:reset": "pnpm --filter=@saas-commerce/api run db:reset"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.15.9"
}
